<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>TextCap</RootNamespace>
    <UseWPF>true</UseWPF>
    <AssemblyName>TextCap</AssemblyName>
    <PlatformTarget>x64</PlatformTarget>
    <Title>TextCap</Title>
    <Description>Convert Revit text-note case (Upper / Lower / Sentence / Title)</Description>
    <Copyright>codehaks</Copyright>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <Import Project="..\Shared\Shared.projitems" Label="Shared" />

  <ItemGroup>
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit 2025\RevitAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit 2025\RevitAPIUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="TextCap.addin">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
